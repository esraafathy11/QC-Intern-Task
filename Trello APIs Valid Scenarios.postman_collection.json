          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "\r",
              "  var responseJSON = pm.response.json();\r",
              "\r",
              "\r",
              "pm.test('Response body is valid JSON object', function () {\r",
              "  pm.expect(responseJSON, 'Invalid JSON').to.be.an('object');\r",
              "});\r",
              "\r",
              "pm.test('Has required fields: name, desc, url', function () {\r",
              "  pm.expect(responseJSON).to.have.property('name');\r",
              "  pm.expect(responseJSON).to.have.property('desc'); // assuming you meant \"desc\" not \"decs\"\r",
              "  pm.expect(responseJSON).to.have.property('url');\r",
              "});\r",
              "\r",
              "pm.test('Permission level is private', function () {\r",
              "  pm.expect(responseJSON).to.have.nested.property('prefs.permissionLevel', 'private');\r",
              "});\r",
              "\r",
              ""
